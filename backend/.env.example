# ─── Database ────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=Cluster0

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=your_strong_secret_key_here_at_least_32_chars

# ─── Server ────────────────────────────────────────────
PORT=5000

# ─── Email (Nodemailer) ───────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── CORS: comma-separated list of allowed frontend origins ───
# Set these to your actual Vercel deployment URLs
ALLOWED_ORIGINS=https://your-user-app.vercel.app,https://your-admin-app.vercel.app
